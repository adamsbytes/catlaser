/target/
**/*.rs.bk
*.pdb
.env
*.snap.new
*.pyc
*.egg-info

# RKNN compiled models (generated from ONNX sources)
*.rknn

# Calibration frames (captured from device, not committed)
models/calibration/*.jpg
models/calibration/*.png

# Deploy build artifacts
deploy/rootfs/usr/bin/catlaser-visiond
deploy/rootfs/usr/bin/catlaser-brain
deploy/rootfs/usr/lib/catlaser-brain/catlaser_brain/
deploy/rootfs/usr/lib/*.rknn

# SwiftPM build artifacts
app/ios/.build/
app/ios/.swiftpm/
app/ios/DerivedData/
app/ios/Package.resolved

# Xcode per-user data
app/ios/**/xcuserdata/
app/ios/**/xcuserstate

# Swift-package-manager-generated xcworkspace (auto-created in .build/)
# but KEEP the xcodeproj's embedded project.xcworkspace (load-bearing).
# The embedded one lives inside a .xcodeproj directory; the autogenerated
# ones live outside any .xcodeproj, at package root.
app/ios/*.xcworkspace/
app/ios/App/*.xcworkspace/
!app/ios/App/*.xcodeproj/project.xcworkspace/
