/target/
**/*.rs.bk
*.pdb
.env
*.snap.new
*.pyc
*.egg-info

# RKNN compiled models (generated from ONNX sources)
*.rknn

# Calibration frames (captured from device, not committed)
models/calibration/*.jpg
