{
  "name": "@catlaser/server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run docker:up && bun run dev:server; bun run docker:down",
    "dev:server": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "prettier --write . && eslint . --cache",
    "lint:fix": "prettier --write . && eslint . --fix --cache",
    "typecheck": "tsc --noEmit",
    "test": "bun run docker:up && bun run db:migrate && bun test; CODE=$?; bun run docker:down; exit $CODE",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "better-auth generate --config ./src/lib/auth.ts --output ./src/db/schema.ts --yes"
  },
  "dependencies": {
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
