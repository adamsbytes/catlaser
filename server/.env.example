NODE_ENV=development
PORT=3000

# Postgres — matches docker-compose.yml
DATABASE_URL=postgres://catlaser:catlaser@localhost:5432/catlaser

# 32+ char random string. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32-output-at-least-32-chars

# Origin of the coordination server as clients see it.
# Production: https://api.catlaser.example (Cloudflare edge hostname)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated allowlist of origins better-auth accepts on authenticated requests.
# Must include the Universal Link / App Links host that magic-link emails point at.
# In production, pin to the Universal Link host only.
TRUSTED_ORIGINS=https://auth.catlaser.example,http://localhost:3000

# Apple "Services ID" registered in Apple Developer (e.g. com.catlaser.app.auth).
# Used as the OAuth client_id for the web / redirect flow; ignored on the
# ID-token-only path the app takes, but better-auth requires the value in the
# provider config.
APPLE_CLIENT_ID=com.catlaser.app.auth

# Apple app bundle identifier (e.g. com.catlaser.app). Native Apple ID tokens
# come back with aud = <bundle id>; the server pins the aud claim against
# this value when verifying Apple tokens from the app.
APPLE_APP_BUNDLE_IDENTIFIER=com.catlaser.app

# Apple Developer Team ID (10-character uppercase alphanumeric). Paired with
# APPLE_APP_BUNDLE_IDENTIFIER to form the "<TeamID>.<BundleID>" appID strings
# published in the AASA (apple-app-site-association) file. iOS refuses to route
# a Universal Link into the app unless this exactly matches the Team ID on the
# Apple Developer account the app is signed with.
APPLE_TEAM_ID=REPLACEME00

# Google OAuth client ID for the iOS application type (registered in Google
# Cloud Console). ID tokens issued to the app carry aud = <client_id>; the
# server pins the aud claim against this value.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# Universal Link (iOS) / App Link (Android) host the magic-link email points
# at. The AASA / assetlinks file on this host MUST associate the path below
# with the app's bundle identifier, so the OS routes taps into the app. The
# server also pins callbackURL submissions on /sign-in/magic-link to this
# host — rejecting anything else closes the phishing-relay takeover vector.
MAGIC_LINK_UNIVERSAL_LINK_HOST=auth.catlaser.example

# Universal Link path. Must start with / and must NOT equal the API verify
# endpoint (/api/v1/auth/magic-link/verify). A browser hitting this path
# receives the inert HTML fallback; only the app unpacks the token and
# completes sign-in against the API verify endpoint.
MAGIC_LINK_UNIVERSAL_LINK_PATH=/sign-in
